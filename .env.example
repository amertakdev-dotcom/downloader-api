# ============================================
# Amertak Network - Downloader API Config
# ============================================

PORT=3000
NODE_ENV=production

# API Secret Key (generate your own random string)
API_SECRET_KEY=your_secret_key_here_change_this

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Spotify (no key needed - uses public scraping)
SPOTIFY_ENABLED=true

# YouTube (no key needed - uses ytdl-core)
YOUTUBE_ENABLED=true

# TikTok (no key needed - uses public API)
TIKTOK_ENABLED=true

# Pinterest (no key needed - uses scraping)
PINTEREST_ENABLED=true

# Optional: Custom User Agent
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
